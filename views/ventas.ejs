<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Panel de Ventas - Marketplace</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Outfit:wght@400;500;600&display=swap" rel="stylesheet">
<style>
:root {
    --primary: #0A0E27;
    --primary-light: #1A1F3A;
    --accent: #00D9FF;
    --accent-glow: rgba(0, 217, 255, 0.3);
    --text: #E8E8E8;
    --text-dim: #A0A0A0;
    --bg: #050816;
    --card-bg: #0F1428;
    --border: rgba(0, 217, 255, 0.2);
    --shadow: rgba(0, 217, 255, 0.1);
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Outfit', sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    position: relative;
    overflow-x: hidden;
}

/* Animated background */
body::before {
    content: '';
    position: fixed;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: 
        radial-gradient(circle at 20% 50%, rgba(0, 217, 255, 0.1) 0%, transparent 50%),
        radial-gradient(circle at 80% 80%, rgba(138, 43, 226, 0.1) 0%, transparent 50%);
    animation: drift 20s ease-in-out infinite;
    pointer-events: none;
    z-index: 0;
}

@keyframes drift {
    0%, 100% { transform: translate(0, 0) rotate(0deg); }
    33% { transform: translate(5%, -5%) rotate(5deg); }
    66% { transform: translate(-5%, 5%) rotate(-5deg); }
}

/* Container */
.container {
    position: relative;
    z-index: 5;
    max-width: 1400px;
    margin: 0 auto;
    padding: 2rem 5%;
}

/* Header Title */
.page-header {
    text-align: center;
    padding: 3rem 0 2rem;
    animation: fadeInUp 0.8s ease;
}

.page-title {
    font-family: 'Sora', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
    background: linear-gradient(135deg, var(--text), var(--accent));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.page-subtitle {
    color: var(--text-dim);
    font-size: 1.1rem;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(20px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

/* Section Headers */
.section-wrapper {
    margin-bottom: 3rem;
    animation: fadeIn 0.6s ease backwards;
}

.section-header {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 16px 16px 0 0;
    padding: 1.5rem 2rem;
    position: relative;
    overflow: hidden;
}

.section-header::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), #8A2BE2);
}

.section-header h3 {
    font-family: 'Sora', sans-serif;
    color: var(--accent);
    font-size: 1.5rem;
    font-weight: 600;
    display: flex;
    align-items: center;
    gap: 0.8rem;
}

.section-icon {
    font-size: 1.8rem;
}

/* Ventas Container */
#ventas, #ventas-con-ubicacion {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-top: none;
    border-radius: 0 0 16px 16px;
    padding: 2rem;
    min-height: 200px;
}

@keyframes fadeIn {
    from { opacity: 0; }
    to { opacity: 1; }
}

/* Venta Card */
.venta-card {
    background: var(--primary-light);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.8rem;
    margin-bottom: 1.5rem;
    transition: all 0.4s cubic-bezier(0.165, 0.84, 0.44, 1);
    position: relative;
    animation: cardAppear 0.6s ease backwards;
}

.venta-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), #0099CC);
    opacity: 0;
    transition: opacity 0.3s ease;
    border-radius: 12px 12px 0 0;
}

.venta-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 40px var(--shadow);
    border-color: var(--accent);
}

.venta-card:hover::before {
    opacity: 1;
}

.venta-card.carrito {
    background: linear-gradient(135deg, var(--primary-light) 0%, rgba(138, 43, 226, 0.1) 100%);
}

@keyframes cardAppear {
    from {
        opacity: 0;
        transform: scale(0.95);
    }
    to {
        opacity: 1;
        transform: scale(1);
    }
}

/* Badge Carrito */
.badge-carrito {
    display: inline-block;
    background: linear-gradient(135deg, var(--accent), #0099CC);
    color: var(--primary);
    padding: 0.4rem 1rem;
    border-radius: 20px;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
    letter-spacing: 0.5px;
}

/* Venta Info */
.venta-info {
    margin-bottom: 1rem;
    display: flex;
    align-items: baseline;
    gap: 0.8rem;
}

.venta-label {
    font-weight: 600;
    color: var(--text);
    min-width: 120px;
    font-size: 0.95rem;
}

.venta-value {
    color: var(--text-dim);
    flex: 1;
}

/* Producto Item */
.producto-item {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: 8px;
    padding: 1.2rem;
    margin: 1rem 0;
}

/* Buttons */
.btn {
    font-family: 'Outfit', sans-serif;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border: none;
    border-radius: 8px;
    position: relative;
    overflow: hidden;
}

.btn-terminar {
    background: linear-gradient(135deg, var(--accent), #0099CC);
    color: var(--primary);
    padding: 0.9rem 1.8rem;
    font-size: 0.95rem;
    box-shadow: 0 4px 15px var(--shadow);
    margin-top: 1rem;
    width: 100%;
}

.btn-terminar:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 25px var(--accent-glow);
}

.btn-terminar:active {
    transform: translateY(0);
}

.btn-ver-terminadas {
    background: var(--card-bg);
    color: var(--text);
    border: 2px solid var(--accent);
    padding: 1.2rem 3rem;
    font-size: 1.1rem;
    display: block;
    margin: 3rem auto;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
}

.btn-ver-terminadas:hover {
    background: var(--primary-light);
    border-color: var(--accent);
    box-shadow: 0 6px 30px var(--accent-glow);
    transform: translateY(-3px);
}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 3rem 2rem;
    color: var(--text-dim);
}

.empty-state-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    opacity: 0.5;
}

/* Dinero Total */
#dinero-total {
    text-align: center;
    font-family: 'Sora', sans-serif;
    font-size: 1.8rem;
    color: var(--accent);
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    position: relative;
    z-index: 5;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

/* Pagination */
.pagination-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    margin: 3rem 0 2rem;
    flex-wrap: wrap;
    animation: fadeInUp 0.8s ease 0.4s backwards;
}

.pagination-btn {
    font-family: 'Outfit', sans-serif;
    background: var(--card-bg);
    color: var(--text);
    border: 1px solid var(--border);
    padding: 0.8rem 1.2rem;
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 8px;
    min-width: 45px;
    text-align: center;
}

.pagination-btn:hover:not(:disabled) {
    background: var(--primary-light);
    border-color: var(--accent);
    transform: translateY(-2px);
    box-shadow: 0 4px 15px var(--shadow);
}

.pagination-btn.active {
    background: linear-gradient(135deg, var(--accent), #0099CC);
    color: var(--primary);
    border-color: var(--accent);
    box-shadow: 0 4px 15px var(--accent-glow);
}

.pagination-btn:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

.pagination-ellipsis {
    color: var(--text-dim);
    padding: 0.8rem 0.5rem;
}

/* Stats Summary */
.stats-summary {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin: 2rem 0 3rem;
    animation: fadeInUp 0.8s ease 0.2s backwards;
}

.stat-card {
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.5rem;
    text-align: center;
    transition: all 0.3s ease;
}

.stat-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px var(--shadow);
    border-color: var(--accent);
}

.stat-number {
    font-family: 'Sora', sans-serif;
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--accent);
    margin-bottom: 0.5rem;
}

.stat-label {
    color: var(--text-dim);
    font-size: 0.95rem;
}

/* Responsive */
@media (max-width: 768px) {
    .page-title {
        font-size: 2rem;
    }

    .page-subtitle {
        font-size: 1rem;
    }

    .section-header h3 {
        font-size: 1.2rem;
    }

    .venta-card {
        padding: 1.5rem;
    }

    .venta-label {
        min-width: 100px;
        font-size: 0.9rem;
    }

    .btn-terminar {
        padding: 0.8rem 1.5rem;
        font-size: 0.9rem;
    }

    .btn-ver-terminadas {
        padding: 1rem 2rem;
        font-size: 1rem;
        width: 90%;
    }

    .stats-summary {
        grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
        gap: 1rem;
    }

    .stat-number {
        font-size: 2rem;
    }
}

@media (max-width: 480px) {
    .container {
        padding: 1rem 4%;
    }

    .venta-info {
        flex-direction: column;
        gap: 0.3rem;
    }

    .venta-label {
        min-width: auto;
    }

    .section-header {
        padding: 1.2rem 1.5rem;
    }

    #ventas, #ventas-con-ubicacion {
        padding: 1.5rem;
    }

    .producto-item {
        padding: 1rem;
    }

    .pagination-container {
        gap: 0.4rem;
    }

    .pagination-btn {
        padding: 0.7rem 1rem;
        font-size: 0.9rem;
        min-width: 40px;
    }

    .stats-summary {
        grid-template-columns: 1fr;
    }
}
</style>
</head>
<body>
<div class="container">
    <div class="page-header">
        <h1 class="page-title">📊 Panel de Ventas</h1>
        <p class="page-subtitle">Gestiona tus pedidos y entregas</p>
    </div>

    <div class="stats-summary" id="stats-summary"></div>

    <h4 id="dinero-total">dinero total:</h4>
    
    <div class="section-wrapper" style="animation-delay: 0.1s">
        <div class="section-header">
            <h3><span class="section-icon">🏪</span> Retiro en Local</h3>
        </div>
        <div id="ventas"></div>
    </div>
    
    <div class="section-wrapper" style="animation-delay: 0.2s">
        <div class="section-header">
            <h3><span class="section-icon">🚚</span> Pedidos con Envío</h3>
        </div>
        <div id="ventas-con-ubicacion"></div>
    </div>

    <div class="pagination-container" id="pagination"></div>
    
    <button class="btn btn-ver-terminadas" onclick="window.location.href='/ventas-terminadas'">
        ✓ Ver Ventas Terminadas
    </button>
</div>

<script src="socket.io/socket.io.js"></script>
<script type="module">
//declaraciones
let ventas= await fetch("/ver-ventas").then(function(res){return res.json()})
console.log(ventas)
let socket= io()
let ventasdiv= document.getElementById("ventas")
let ventas_con_ubicaciondiv= document.getElementById("ventas-con-ubicacion")

const response = await fetch("https://open.er-api.com/v6/latest/USD");
const data = await response.json();
const dolarAuyu = data.rates.UYU;

// SOLO AGREGADO: Variables de paginación
const ITEMS_PER_PAGE = 10
let currentPage = 1
let totalPages = 1

// SOLO AGREGADO: Función para cambiar de página
window.cambiarPagina = function(nuevaPagina) {
    if (nuevaPagina < 1 || nuevaPagina > totalPages) return
    currentPage = nuevaPagina
    ventasuwu()
}

// SOLO AGREGADO: Función para renderizar paginación
function renderPagination() {
    const paginationContainer = document.getElementById("pagination")
    
    if (totalPages <= 1) {
        paginationContainer.innerHTML = ""
        return
    }
    
    let paginationHTML = ""
    
    paginationHTML += `
        <button class="pagination-btn" onclick="cambiarPagina(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>
            ← Anterior
        </button>
    `
    
    const maxButtons = 7
    let startPage = Math.max(1, currentPage - Math.floor(maxButtons / 2))
    let endPage = Math.min(totalPages, startPage + maxButtons - 1)
    
    if (endPage - startPage < maxButtons - 1) {
        startPage = Math.max(1, endPage - maxButtons + 1)
    }
    
    if (startPage > 1) {
        paginationHTML += `<button class="pagination-btn" onclick="cambiarPagina(1)">1</button>`
        if (startPage > 2) {
            paginationHTML += `<span class="pagination-ellipsis">...</span>`
        }
    }
    
    for (let i = startPage; i <= endPage; i++) {
        paginationHTML += `
            <button class="pagination-btn ${i === currentPage ? 'active' : ''}" onclick="cambiarPagina(${i})">
                ${i}
            </button>
        `
    }
    
    if (endPage < totalPages) {
        if (endPage < totalPages - 1) {
            paginationHTML += `<span class="pagination-ellipsis">...</span>`
        }
        paginationHTML += `<button class="pagination-btn" onclick="cambiarPagina(${totalPages})">${totalPages}</button>`
    }
    
    paginationHTML += `
        <button class="pagination-btn" onclick="cambiarPagina(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>
            Siguiente →
        </button>
    `
    
    paginationContainer.innerHTML = paginationHTML
}

window.eliminarventa= async function eliminarventa(id){
    await fetch("/eliminar-venta",{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({id:id})
    })
}

//websocket
socket.on("compras",async function(){
    ventas= await fetch("/ver-ventas").then(function(res){return res.json()})
    ventasuwu()
})

//declaracion de funciones
function ventasuwu(){
    // SOLO AGREGADO: Calcular paginación
    totalPages = Math.ceil(ventas.length / ITEMS_PER_PAGE)
    const startIndex = (currentPage - 1) * ITEMS_PER_PAGE
    const endIndex = startIndex + ITEMS_PER_PAGE
    const ventas_pagina = ventas.slice(startIndex, endIndex)
    
    // TU CÓDIGO ORIGINAL - SIN MODIFICAR
    ventasdiv.innerHTML=""
    ventas_con_ubicaciondiv.innerHTML=""
    
    let precio=0
    
    let ventasLocales = 0
    let ventasEnvio = 0
    let cardDelay = 0
    
    for(let venta of ventas_pagina){ // SOLO CAMBIADO: ventas -> ventas_pagina
        // Ventas sin ubicación (retiro en local)
        if(venta.productos.length===0 && (venta.local_ubicacion.includes("no definida") || venta.local_ubicacion==="")){
            if(venta.producto_precio.includes("US$")){precio+=Number(venta.producto_precio.match(/\d+/))*dolarAuyu}
            else{precio+=Number(venta.producto_precio.match(/\d+/))}
            ventasLocales++
            ventasdiv.innerHTML+=`
                <div class="venta-card" style="animation-delay: ${cardDelay * 0.05}s">
                    <div class="venta-info">
                        <span class="venta-label">👤 Comprador:</span>
                        <span class="venta-value">${venta.usuario}</span>
                    </div>
                    <div class="venta-info">
                        <span class="venta-label">📦 Producto:</span>
                        <span class="venta-value">${venta.producto_nombre}</span>
                    </div>
                    <div class="venta-info">
                        <span class="venta-label">💰 Precio:</span>
                        <span class="venta-value">$${venta.producto_precio}</span>
                    </div>
                    <button class="btn btn-terminar" onclick='eliminarventa("${venta._id}")'>
                        ✓ Marcar como Terminada
                    </button>
                </div>
            `
            cardDelay++
        } 
        
        // Carritos sin ubicación
        if(venta.productos.length!==0 && venta.local_ubicacion.includes("no definida")){ 
            
            ventasLocales++
            ventasdiv.innerHTML+=`
                <div class="venta-card carrito" style="animation-delay: ${cardDelay * 0.05}s">
                    <span class="badge-carrito">🛒 CARRITO</span>
                    <div class="venta-info">
                        <span class="venta-label">👤 Comprador:</span>
                        <span class="venta-value">${venta.usuario}</span>
                    </div>
            `
            for(let producto of venta.productos){
                if(producto.producto_precio.includes("US$")){precio+=Number(producto.producto_precio.match(/\d+/))*dolarAuyu}
            else{precio+=Number(producto.producto_precio.match(/\d+/))}
                ventasdiv.innerHTML +=`
                    <div class="producto-item">
                        <div class="venta-info">
                            <span class="venta-label">📦 Producto:</span>
                            <span class="venta-value">${producto.producto_nombre}</span>
                        </div>
                        <div class="venta-info">
                            <span class="venta-label">💰 Precio:</span>
                            <span class="venta-value">$${producto.producto_precio}</span>
                        </div>
                    </div>
                `  
            }
            ventasdiv.innerHTML+=`
                    <button class="btn btn-terminar" onclick='eliminarventa("${venta._id}")'>
                        ✓ Marcar como Terminada
                    </button>
                </div>
            `
            cardDelay++
        }
        
        // Ventas con ubicación (envíos)
        if(venta.productos.length===0 && !venta.local_ubicacion.includes("no definida")){
            if(venta.producto_precio.includes("US$")){precio+=Number(venta.producto_precio.match(/\d+/))*dolarAuyu}
            if(venta.producto_envio.includes("US$")){precio+=Number(venta.producto_envio.match(/\d+/))*dolarAuyu}
            else{precio+=Number(venta.producto_precio.match(/\d+/))+ Number(venta.producto_envio.match(/\d+/))}
            ventasEnvio++
            ventas_con_ubicaciondiv.innerHTML+=`
                <div class="venta-card" style="animation-delay: ${cardDelay * 0.05}s">
                    <div class="venta-info">
                        <span class="venta-label">👤 Comprador:</span>
                        <span class="venta-value">${venta.usuario}</span>
                    </div>
                    <div class="venta-info">
                        <span class="venta-label">📦 Producto:</span>
                        <span class="venta-value">${venta.producto_nombre}</span>
                    </div>
                    <div class="venta-info">
                        <span class="venta-label">💰 Precio:</span>
                        <span class="venta-value">$${venta.producto_precio}</span>
                    </div>
                    <div class="venta-info">
                        <span class="venta-label">🚚 Envío:</span>
                        <span class="venta-value">$${venta.producto_envio}</span>
                    </div>
                    <div class="venta-info">
                        <span class="venta-label">📍 Domicilio:</span>
                        <span class="venta-value">${venta.local_ubicacion}</span>
                    </div>
                    <button class="btn btn-terminar" onclick='eliminarventa("${venta._id}")'>
                        ✓ Marcar como Terminada
                    </button>
                </div>
            `
            cardDelay++
        }
        
        // Carritos con ubicación
        if(venta.productos.length!==0 && !venta.local_ubicacion.includes("no definida")){
            ventasEnvio++
            ventas_con_ubicaciondiv.innerHTML+=`
                <div class="venta-card carrito" style="animation-delay: ${cardDelay * 0.05}s">
                    <span class="badge-carrito">🛒 CARRITO</span>
                    <div class="venta-info">
                        <span class="venta-label">👤 Comprador:</span>
                        <span class="venta-value">${venta.usuario}</span>
                    </div>
            `
            for(let producto of venta.productos){
                if(producto.producto_envio.includes("US$")){precio+=Number(producto.producto_envio.match(/\d+/))*dolarAuyu}
                if(producto.producto_precio.includes("US$")){precio+=Number(producto.producto_precio.match(/\d+/))*dolarAuyu}
            else{precio+=Number(producto.producto_precio.match(/\d+/))+ Number(producto.producto_envio.match(/\d+/)) }
            
                ventas_con_ubicaciondiv.innerHTML +=`
                    <div class="producto-item">
                        <div class="venta-info">
                            <span class="venta-label">📦 Producto:</span>
                            <span class="venta-value">${producto.producto_nombre}</span>
                        </div>
                        <div class="venta-info">
                            <span class="venta-label">💰 Precio:</span>
                            <span class="venta-value">$${producto.producto_precio}</span>
                        </div>
                    </div>
                ` 
            }
            ventas_con_ubicaciondiv.innerHTML+=`
                    <div class="venta-info">
                        <span class="venta-label">🚚 Envío:</span>
                        <span class="venta-value">$${venta.producto_envio}</span>
                    </div>
                    <div class="venta-info">
                        <span class="venta-label">📍 Domicilio:</span>
                        <span class="venta-value">${venta.local_ubicacion}</span>
                    </div>
                    <button class="btn btn-terminar" onclick='eliminarventa("${venta._id}")'>
                        ✓ Marcar como Terminada
                    </button>
                </div>
            `
            cardDelay++
        } 
    }
    
    // Mensajes si no hay ventas
    if(ventasLocales === 0){
        ventasdiv.innerHTML = `
            <div class="empty-state">
                <div class="empty-state-icon">🏪</div>
                <p>No hay ventas para retiro en local</p>
            </div>
        `
    }
    if(ventasEnvio === 0){
        ventas_con_ubicaciondiv.innerHTML = `
            <div class="empty-state">
                <div class="empty-state-icon">🚚</div>
                <p>No hay pedidos con envío</p>
            </div>
        `
    }
    
    // Contar totales de TODAS las ventas (no solo de la página actual)
    let totalLocalesCompleto = 0
    let totalEnviosCompleto = 0
    for(let venta of ventas){
        if(venta.local_ubicacion.includes("no definida") || venta.local_ubicacion===""){
            totalLocalesCompleto++
        } else {
            totalEnviosCompleto++
        }
    }
    
    // Estadísticas
    const statsContainer = document.getElementById("stats-summary")
    statsContainer.innerHTML = `
        <div class="stat-card">
            <div class="stat-number">${ventas.length}</div>
            <div class="stat-label">Compras Totales</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">${totalLocalesCompleto}</div>
            <div class="stat-label">Retiro en Local</div>
        </div>
        <div class="stat-card">
            <div class="stat-number">${totalEnviosCompleto}</div>
            <div class="stat-label">Pedidos con Envío</div>
        </div>
    `
    
    document.getElementById("dinero-total").textContent=`dinero ganado:$${precio}`
    
    // SOLO AGREGADO: Renderizar paginación y scroll
    renderPagination()
    window.scrollTo({ top: 0, behavior: 'smooth' })
}

//codigo
ventasuwu()
</script>
</body>
</html>
