<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Tickets</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Work+Sans:wght@300;400;600&display=swap" rel="stylesheet">
<style>
    :root {
        --bg-dark: #0f0f23;
        --bg-card: #1a1a2e;
        --border-color: #2d2d44;
        --accent-primary: #00ff88;
        --accent-secondary: #0aefff;
        --text-primary: #f0f0f5;
        --text-secondary: #b0b0c0;
        --text-dim: #707080;
    }

    * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    body {
        font-family: 'Work Sans', -apple-system, sans-serif;
        background: var(--bg-dark);
        color: var(--text-primary);
        min-height: 100vh;
        padding: 3rem 1.5rem;
        background-image: 
            radial-gradient(circle at 10% 20%, rgba(0, 255, 136, 0.08) 0%, transparent 40%),
            radial-gradient(circle at 90% 80%, rgba(10, 239, 255, 0.06) 0%, transparent 40%);
    }

    body::before {
        content: '';
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: 
            repeating-linear-gradient(
                90deg,
                transparent,
                transparent 80px,
                rgba(0, 255, 136, 0.02) 80px,
                rgba(0, 255, 136, 0.02) 81px
            );
        pointer-events: none;
        z-index: 0;
    }

    h1 {
        font-family: 'Bebas Neue', sans-serif;
        font-size: clamp(3rem, 10vw, 5rem);
        letter-spacing: 0.05em;
        margin-bottom: 2.5rem;
        background: linear-gradient(120deg, var(--accent-primary), var(--accent-secondary));
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
        position: relative;
        z-index: 1;
        text-transform: uppercase;
        animation: fadeSlideDown 0.8s ease-out;
    }

    h1::after {
        content: '';
        position: absolute;
        bottom: -12px;
        left: 0;
        width: 80px;
        height: 3px;
        background: var(--accent-primary);
        box-shadow: 0 0 20px rgba(0, 255, 136, 0.5);
    }

    .back-btn {
        display: inline-block;
        padding: 0.8rem 2rem;
        margin-bottom: 2rem;
        background: var(--bg-card);
        color: var(--accent-primary);
        text-decoration: none;
        border: 2px solid var(--border-color);
        border-radius: 8px;
        font-weight: 600;
        font-size: 0.95rem;
        transition: all 0.3s ease;
        position: relative;
        z-index: 1;
    }

    .back-btn:hover {
        background: var(--accent-primary);
        color: var(--bg-dark);
        border-color: var(--accent-primary);
        box-shadow: 0 0 20px rgba(0, 255, 136, 0.3);
        transform: translateX(-4px);
    }

    #tickets {
        max-width: 800px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    #tickets p {
        font-size: 0.95rem;
        line-height: 1.8;
        color: var(--text-secondary);
        padding: 0.4rem 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        transition: all 0.2s ease;
    }

    #tickets p:hover {
        color: var(--text-primary);
        padding-left: 8px;
        border-bottom-color: rgba(0, 255, 136, 0.2);
    }

    #tickets p:first-of-type {
        font-weight: 600;
        color: var(--accent-primary);
        font-size: 1.05rem;
        border-bottom: 2px solid var(--border-color);
        padding: 0.6rem 0;
        margin-top: 2rem;
    }

    #tickets br + p {
        margin-top: 0.3rem;
    }

    @keyframes fadeSlideDown {
        from {
            opacity: 0;
            transform: translateY(-30px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @media (max-width: 600px) {
        body {
            padding: 2rem 1rem;
        }
        
        h1 {
            font-size: 2.5rem;
        }
    }
</style>
</head>
<body>
<a href="/tienda" class="back-btn">← Volver a la tienda</a>
<h1>tus tickets:</h1>
<div id="tickets"></div>
<script type="module">
let tickets= await fetch("/ver-tickets").then(function(res){return res.json()})
console.log(tickets)
let ticketsdiv= document.getElementById("tickets")
if(tickets.length!==0){
for(let ticket of tickets){
if(ticket.producto_nombre){
ticketsdiv.innerHTML+=`
            <p>usuario:${ticket.usuario}</p>
          <p>productos: ${ticket.producto_nombre}</p>
        <p>precio:${ticket.producto_precio}</p>
        <p>tiempo:${ticket.Date}</p>
        <p>id:${ticket._id}</p> <br>
        --------------------------------`
            }
else{ticketsdiv.innerHTML+=`
            <p>usuario:${ticket.usuario}</p>
        <p>tiempo:${ticket.Date}</p>`
for(let producto of ticket.productos){
ticketsdiv.innerHTML+=`producto:${producto.producto_nombre}  <br>
            precio: ${producto.producto_precio}  <br>  <br>`
        }
ticketsdiv.innerHTML+=`precio total: ${ticket.precio_total} <br>
    ---------------------------------`}
                }
        }
</script>
</body>
</html>
