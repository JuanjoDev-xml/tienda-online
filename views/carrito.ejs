<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Carrito de Compras - Marketplace</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Sora:wght@300;400;600;700&family=Outfit:wght@400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #0A0E27;
            --primary-light: #1A1F3A;
            --accent: #00D9FF;
            --accent-secondary: #8A2BE2;
            --accent-glow: rgba(0, 217, 255, 0.3);
            --text: #E8E8E8;
            --text-dim: #A0A0A0;
            --bg: #050816;
            --card-bg: #0F1428;
            --border: rgba(0, 217, 255, 0.2);
            --shadow: rgba(0, 217, 255, 0.1);
            --danger: #FF4444;
            --success: #00FF88;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            position: relative;
            overflow-x: hidden;
        }

        body::before {
            content: '';
            position: fixed;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: 
                radial-gradient(circle at 20% 50%, rgba(0, 217, 255, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 80%, rgba(138, 43, 226, 0.1) 0%, transparent 50%);
            animation: drift 20s ease-in-out infinite;
            pointer-events: none;
            z-index: 0;
        }

        @keyframes drift {
            0%, 100% { transform: translate(0, 0) rotate(0deg); }
            33% { transform: translate(5%, -5%) rotate(5deg); }
            66% { transform: translate(-5%, 5%) rotate(-5deg); }
        }

        /* Container */
        .container {
            position: relative;
            z-index: 1;
            max-width: 1200px;
            margin: 0 auto;
            padding: 2rem 5%;
        }

        /* Header */
        .page-header {
            text-align: center;
            margin-bottom: 3rem;
            animation: fadeInUp 0.8s ease;
        }

        .page-title {
            font-family: 'Sora', sans-serif;
            font-size: 2.5rem;
            font-weight: 700;
            background: linear-gradient(135deg, var(--text), var(--accent));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            margin-bottom: 0.5rem;
        }

        .welcome-text {
            font-size: 1.2rem;
            color: var(--text-dim);
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* Cart Layout */
        .cart-layout {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 2rem;
            animation: fadeIn 0.6s ease;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Cart Items Section */
        .cart-items-section {
            display: flex;
            flex-direction: column;
            gap: 1rem;
        }

        .section-title {
            font-family: 'Sora', sans-serif;
            font-size: 1.5rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .cart-count {
            background: var(--accent);
            color: var(--primary);
            padding: 0.2rem 0.6rem;
            border-radius: 20px;
            font-size: 0.9rem;
            font-weight: 600;
        }

        /* Cart Item Card */
        .cart-item {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 1.5rem;
            display: flex;
            gap: 1.5rem;
            transition: all 0.3s ease;
            animation: slideIn 0.4s ease backwards;
        }

        @keyframes slideIn {
            from {
                opacity: 0;
                transform: translateX(-20px);
            }
            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        .cart-item:hover {
            border-color: var(--accent);
            box-shadow: 0 8px 30px var(--shadow);
        }

        .item-image-container {
            flex-shrink: 0;
            width: 150px;
            height: 150px;
            border-radius: 12px;
            overflow: hidden;
            background: var(--primary);
            position: relative;
        }

        .item-image-container::before {
            content: '📦';
            position: absolute;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%);
            font-size: 3rem;
            opacity: 0.3;
            z-index: 0;
        }

        .item-image {
            width: 100%;
            height: 100%;
            object-fit: cover;
            position: relative;
            z-index: 1;
            transition: transform 0.3s ease;
        }

        .cart-item:hover .item-image {
            transform: scale(1.1);
        }

        .item-details {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .item-name {
            font-family: 'Sora', sans-serif;
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--text);
            text-decoration: none;
            transition: color 0.3s ease;
            margin-bottom: 0.5rem;
        }

        .item-name:hover {
            color: var(--accent);
        }

        .item-price {
            font-family: 'Sora', sans-serif;
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--accent);
            margin-bottom: 1rem;
        }

        .item-actions {
            display: flex;
            gap: 0.8rem;
        }

        /* Buttons */
        .btn {
            padding: 0.7rem 1.5rem;
            border: none;
            border-radius: 8px;
            font-family: 'Outfit', sans-serif;
            font-size: 0.9rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }

        .btn::before {
            content: '';
            position: absolute;
            top: 50%;
            left: 50%;
            width: 0;
            height: 0;
            border-radius: 50%;
            background: rgba(255, 255, 255, 0.2);
            transform: translate(-50%, -50%);
            transition: width 0.6s, height 0.6s;
        }

        .btn:active::before {
            width: 300px;
            height: 300px;
        }

        .btn-view {
            background: var(--primary-light);
            color: var(--text);
            border: 1px solid var(--border);
        }

        .btn-view:hover {
            background: var(--primary);
            border-color: var(--accent);
        }

        .btn-remove {
            background: rgba(255, 68, 68, 0.1);
            color: var(--danger);
            border: 1px solid rgba(255, 68, 68, 0.3);
        }

        .btn-remove:hover {
            background: var(--danger);
            color: white;
            border-color: var(--danger);
        }

        /* Summary Section */
        .cart-summary {
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
            padding: 2rem;
            height: fit-content;
            position: sticky;
            top: 2rem;
        }

        .summary-title {
            font-family: 'Sora', sans-serif;
            font-size: 1.3rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 1.5rem;
        }

        .summary-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1rem 0;
            border-bottom: 1px solid var(--border);
        }

        .summary-row:last-of-type {
            border-bottom: none;
        }

        .summary-label {
            color: var(--text-dim);
            font-size: 0.95rem;
        }

        .summary-value {
            font-weight: 600;
            color: var(--text);
        }

        .summary-total {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 1.5rem 0;
            margin-top: 1rem;
            border-top: 2px solid var(--border);
        }

        .total-label {
            font-family: 'Sora', sans-serif;
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text);
        }

        .total-value {
            font-family: 'Sora', sans-serif;
            font-size: 2rem;
            font-weight: 700;
            color: var(--accent);
        }

        .btn-checkout {
            width: 100%;
            padding: 1.2rem;
            margin-top: 1.5rem;
            background: linear-gradient(135deg, var(--accent), #0099CC);
            color: var(--primary);
            font-size: 1.1rem;
            font-weight: 600;
            box-shadow: 0 4px 15px var(--shadow);
        }

        .btn-checkout:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px var(--accent-glow);
        }

        .btn-checkout:disabled {
            opacity: 0.5;
            cursor: not-allowed;
            transform: none;
        }

        /* Empty Cart */
        .empty-cart {
            grid-column: 1 / -1;
            text-align: center;
            padding: 4rem 2rem;
            background: var(--card-bg);
            border: 1px solid var(--border);
            border-radius: 16px;
        }

        .empty-icon {
            font-size: 5rem;
            margin-bottom: 1rem;
        }

        .empty-title {
            font-family: 'Sora', sans-serif;
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--text);
            margin-bottom: 0.5rem;
        }

        .empty-text {
            color: var(--text-dim);
            margin-bottom: 2rem;
        }

        .btn-shop {
            background: linear-gradient(135deg, var(--accent), #0099CC);
            color: var(--primary);
            padding: 1rem 2rem;
            font-size: 1rem;
            font-weight: 600;
            box-shadow: 0 4px 15px var(--shadow);
        }

        .btn-shop:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 25px var(--accent-glow);
        }

        /* Removing animation */
        .cart-item.removing {
            animation: slideOut 0.3s ease forwards;
        }

        @keyframes slideOut {
            from {
                opacity: 1;
                transform: translateX(0);
                max-height: 200px;
            }
            to {
                opacity: 0;
                transform: translateX(-20px);
                max-height: 0;
                margin: 0;
                padding: 0;
            }
        }

        /* Responsive */
        @media (max-width: 968px) {
            .cart-layout {
                grid-template-columns: 1fr;
            }

            .cart-summary {
                position: relative;
                top: 0;
            }

            .page-title {
                font-size: 2rem;
            }

            .cart-item {
                flex-direction: column;
            }

            .item-image-container {
                width: 100%;
                height: 200px;
            }
        }

        @media (max-width: 640px) {
            .container {
                padding: 1rem 4%;
            }

            .page-header {
                margin-bottom: 2rem;
            }

            .cart-item {
                padding: 1rem;
            }

            .item-actions {
                flex-direction: column;
            }

            .btn {
                width: 100%;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="page-header">
            <h1 class="page-title">🛒 Carrito de Compras</h1>
            <p class="welcome-text">Hola, <%= usuario %></p>
        </div>

        <div class="cart-layout" id="cart-container">
            <!-- Cart items will be inserted here -->
        </div>
    </div>
   

    <script src="/socket.io/socket.io.js"></script>    
    <script type="module">
       
        // --------------- Declaraciones -----------------
        let carrito = await fetch("/ver-carrito").then(res => res.json());
        let verificador= false
        let socket=io()
        let z=0
            socket.on("quitar-carrito",async function(){  carrito = await fetch("/ver-carrito").then(res => res.json());
                verificador=true
                actualizarTotal()
            })
           let summaryHTML1=""
            let itemsHTML=""
       
        
        let cartContainer = document.getElementById("cart-container");
        console.log("Carrito:", carrito);
        let precio = 0;
        let precioenvio=0
        let products= await fetch("/verproductos").then(function(res){return res.json()})
        
            const response = await fetch("https://open.er-api.com/v6/latest/USD")
;

const data = await response.json();

const dolarAuyu =data.rates.UYU;
console.log(dolarAuyu)

        // ---------- Declaración de funciones -------------
        window.pagarcarrito = async function pagarcarrito() {
            while(z<products.length){
                for(let productos of carrito){if(products[z].producto_id===productos.producto_id && products[z].producto_stock==0){
                    alert("uno de los productos se quedó sin stock, por favor agregue al carrito solo productos disponibles"); return
                }} ++z
            }
            if(document.querySelector(`input[name="respuesta"]:checked`) && document.querySelector(`input[name="respuesta"]:checked`).value==="si"){window.location.href="/compra-carrito"}
            else{const checkoutBtn = document.getElementById("checkout-btn");
            checkoutBtn.disabled = true;
            checkoutBtn.textContent = "Procesando...";
            
            try {
                const res = await fetch("/comprar-carrito",{method:"POST",headers:{"Content-Type":"application/json"},body:
                   JSON.stringify({ubicacion:" no definida (se recogerá en el local)"}) }
                ).then(res => res.json());
                window.location.href = res.init_point;
            } catch (error) {
                console.error("Error al procesar pago:", error);
                checkoutBtn.disabled = false;
                checkoutBtn.textContent = "💳 Proceder al Pago";
                alert("Error al procesar el pago. Intenta nuevamente.");
            }
        }}

        window.quitarproducto = async function quitarproducto(id) {
            if(verificador===false){return}
            
            console.log("Quitando producto ID:", id);
            
            const divid = document.getElementById(`item-${id}`);
            
            if (divid) {
                divid.classList.add('removing');
                
                setTimeout(async () => {
                    await fetch("/quitar-del-carrito", {
                        method: "POST",
                        headers: {"Content-Type": "application/json"},
                        body: JSON.stringify({id: id})
                    });
                    
                    divid.remove();
                    
                    // Actualizar carrito
                    carrito = carrito.filter(p => p.producto_id !== id);
                    
                    // Si el carrito queda vacío
                    if (carrito.length === 0) {
                        mostrarCarritoVacio();
                    }
                }, 300);
            }verificador=false}
            
        

        function actualizarTotal() {
            precio = 0;
            for (let producto of carrito) {
                const precioNumerico = Number(producto.producto_precio.match(/\d+/)[0])
                if (producto.producto_precio.includes("US$")){precioNumerico*40};
                precio += precioNumerico;

                
            }
            console.log("precio",precio)
          let summaryHTML = ` <span id="subtotal" class="summary-value">$${precio}</span>
                    
            
            
            `;
           console.log("lo incluye?",cartContainer.innerHTML.includes(summaryHTML1));
                if(carrito.length!==0){ document.getElementById("subtotal").innerHTML=summaryHTML}
           
            const totalElement = document.getElementById("total-price");
            const itemsCountElement = document.getElementById("items-count");
            
            if (totalElement) {
                totalElement.textContent = `$${precio}`;
            }
            
            if (itemsCountElement) {
                itemsCountElement.textContent = carrito.length;
            }

        
        }

        function mostrarCarritoVacio() {
            cartContainer.innerHTML = `
                <div class="empty-cart">
                    <div class="empty-icon">🛒</div>
                    <h2 class="empty-title">Tu carrito está vacío</h2>
                    <p class="empty-text">Agrega productos para comenzar a comprar</p>
                    <button onclick="window.location.href='/tienda/<%= usuario %>'" class="btn btn-shop">
                        Explorar Productos
                    </button>
                </div>
            `;
        }

        function renderizarCarrito() {
            if (carrito.length === 0) {
                mostrarCarritoVacio();
                return;
            }

            // Calcular total
             precioenvio=0; console.log("carrito:xd",carrito)
            for (let producto of carrito) {
                let precioNumerico = Number(producto.producto_precio.match(/\d+/)[0]);
                if (producto.producto_precio.includes("US$")){precioNumerico=precioNumerico*dolarAuyu}
                precio += precioNumerico;
                console.log(producto.producto_envio,"producto_envio")
                if(producto.producto_envio!==undefined &&producto.producto_envio.includes("US$")){producto.producto_envio=Number(producto.producto_envio.match(/\d+/)[0])*dolarAuyu}
                if(producto.producto_envio!==undefined){ console.log("precio de envio:", precioenvio)
                    if(Number(producto.producto_envio.match(/\d+/)[0])>precioenvio) {precioenvio= Number(producto.producto_envio.match(/\d+/)[0])}
                
            }}
            let a=0
            let preciocoma=""
        if(precio.toString().includes(".")){for(let numcomas of  precio.toString().split(".")[1] ){ if(a<2){preciocoma+=numcomas} ++a
                
            }  precio= precio.toString().split(".")[0] + "." + preciocoma
} 
            
            // Items Section
             itemsHTML = `
                <div class="cart-items-section">
                    <h2 class="section-title">
                        Productos <span class="cart-count" id="items-count">${carrito.length}</span>
                    </h2>
            `;

            carrito.forEach((producto, index) => { let productoposta;
                for(let productoreal of products){if(productoreal.producto_id===producto.producto_id){productoposta=productoreal}}
                let imagenSrc = '';
                
                if (producto.producto_imagen) {
                    if (Array.isArray(producto.producto_imagen) && producto.producto_imagen.length > 0) {
                        if (typeof producto.producto_imagen[0] === 'object' && producto.producto_imagen[0].filename) {
                            imagenSrc = `/${producto.producto_imagen[0].filename}`;
                        } else if (typeof producto.producto_imagen[0] === 'string') {
                            imagenSrc = `/${producto.producto_imagen[0]}`;
                        }
                    } else if (typeof producto.producto_imagen === 'string') {
                        imagenSrc = producto.producto_imagen.startsWith('/') ? producto.producto_imagen : `/${producto.producto_imagen}`;
                    }
                }
                
                if (!imagenSrc) {
                    imagenSrc = '/placeholder.png';
                }

                itemsHTML += `
                    <div class="cart-item" id="item-${producto.producto_id}" style="animation-delay: ${index * 0.1}s">
                        <div class="item-image-container">
                            <img src="${imagenSrc}" alt="${producto.producto_nombre}" class="item-image" 
                                 onerror="this.onerror=null; this.src='/placeholder.png';">
                        </div>
                        <div class="item-details">
                            <a href="/producto/${encodeURIComponent(producto.producto_nombre)}/${producto.producto_id}" class="item-name">
                                ${producto.producto_nombre}
                            </a>
                            <div class="item-price">${producto.producto_precio}</div>
                            <div class="item-actions">
                                <p>stock: ${productoposta.producto_stock} </p>
                                <button onclick="window.location.href='/producto/${encodeURIComponent(producto.producto_nombre)}/${producto.producto_id}'" class="btn btn-view">
                                    👁️ Ver Producto
                                </button>
                                <button onclick="quitarproducto('${producto.producto_id}')" class="btn btn-remove">
                                    🗑️ Eliminar
                                </button>
                            </div>
                        </div>
                    </div>
                `;
            });

            itemsHTML += `</div>`;

            // Summary Section
         summaryHTML1 = `
                <div class="cart-summary">
                    <h3 class="summary-title">Resumen del Pedido</h3>
                    
                    <div class="summary-row">
                        <span class="summary-label">Subtotal</span>
                        <span id="subtotal" class="summary-value">$${precio}</span>
                    </div>
                    
                    <div class="summary-row">
                        <span class="summary-label">Envío</span>
                        <span class="summary-value">$${precioenvio}</span>
                    </div>
                    
                    <div class="summary-total">
                        <span class="total-label">Total</span>
                        <span class="total-value" id="total-price">$${Number(precio) + Number(precioenvio)}</span>
                    </div>
                         <p>¿desea incluir gastos de envío?</p>
            <label >
            <input type="radio" name="respuesta" value="si">
            si
         </label>

          <label >
            <input type="radio" name="respuesta" value="no">
            no
         </label>
                    <button onclick="pagarcarrito()" class="btn btn-checkout" id="checkout-btn">
                        💳 Proceder al Pago
                    </button>
                    
                    <button onclick="window.location.href='/tienda/<%= usuario %>'" class="btn btn-view" style="width: 100%; margin-top: 1rem;">
                        ← Seguir Comprando
                    </button>
                </div>
            `;

            cartContainer.innerHTML = itemsHTML + summaryHTML1;
        }

        // ----------------- Código ----------------------
        renderizarCarrito();
        console.log("Total del carrito: $" + precio);
    </script>
</body>
</html>
